// DataPilot app DB schema — Prisma only ever touches this database.
// The user's target database is never modeled here; see backend/src/userdb.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  // Ephemeral demo tenants (created by POST /auth/demo). Swept after 24h;
  // deleting the user cascades through Connection -> SchemaProfile/QueryLog.
  isDemo       Boolean      @default(false)
  createdAt    DateTime     @default(now())
  connections  Connection[]
  queryLogs    QueryLog[]
}

model Connection {
  id                      String         @id @default(uuid())
  userId                  String
  user                    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                    String
  // AES-256-GCM: ciphertext, IV, and auth tag stored separately, never logged or returned to the client.
  connectionStringCipher  String
  connectionStringIv      String
  connectionStringTag     String
  createdAt               DateTime       @default(now())
  lastScannedAt           DateTime?
  // Whether the supplied credential can actually modify data, probed at
  // connect/rescan. null = never probed (row predates the check, or the probe
  // failed). Informational only — the read-only session flag and AST validation
  // still apply regardless.
  credentialCanWrite      Boolean?
  schemaProfile           SchemaProfile?
  queryLogs               QueryLog[]

  @@index([userId])
}

model SchemaProfile {
  id           String     @id @default(uuid())
  connectionId String     @unique
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  scannedAt    DateTime   @default(now())
  // TableProfile[] as defined in engine/types.ts, stored whole — introspection re-scans replace it entirely.
  tables       Json
  // Cached business-language summary (ConnectionSummary in engine/types.ts).
  // Costs an LLM call to build, so it is generated once on first request and
  // served from here after. Nulled on rescan, because the schema it describes
  // has changed.
  summary      Json?
}

model QueryLog {
  id               String     @id @default(uuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectionId     String
  connection       Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  question         String
  retrievedTables  Json?
  sql              String?
  validationResult Json?
  executionResult  Json?
  errorText        String?
  attemptNumber    Int
  latencyMs        Int
  createdAt        DateTime   @default(now())

  @@index([userId])
  @@index([connectionId])
}
