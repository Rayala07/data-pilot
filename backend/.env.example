# App DB (Supabase) — Prisma. Pooled connection for the app at runtime.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection — required by Prisma migrations, and for anything needing session-level features.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"

# Connection-string-at-rest encryption. Must be a 64-char hex string (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"

# Server
# Set NODE_ENV=production when deploying. It switches CORS from "any localhost
# origin" to a strict allowlist, and makes DEV_POISON_COLUMN a startup error.
# NOTE: npm omits devDependencies when NODE_ENV=production, so a build that
# needs typescript/prisma must run `npm install --include=dev`.
# NODE_ENV="production"
PORT=4000
# Browser origin(s) CORS accepts. Comma-separated list allowed.
FRONTEND_URL="http://localhost:3000"

# --- LLM / embeddings (provider-agnostic, any OpenAI-compatible API) ---
# LLM and embeddings are configured independently and CAN use different
# providers. Here: chat via OpenRouter, embeddings via Google Gemini.
# LLM_API_KEY / EMBEDDING_API_KEY fall back to OPENROUTER_API_KEY if unset.
OPENROUTER_API_KEY=""

# Chat (SQL generation, table descriptions) via OpenRouter
LLM_BASE_URL="https://openrouter.ai/api/v1"
LLM_API_KEY=""
LLM_MODEL="qwen/qwen3-coder"
# Cap completion tokens — OpenRouter reserves credits up to this, and our
# prompts (descriptions, SQL) are short.
LLM_MAX_TOKENS="1024"

# Embeddings via Google Gemini's OpenAI-compatible endpoint (free key from
# aistudio.google.com). qwen3-embedding-8b was tried and discriminated poorly
# on this same-domain retrieval task; gemini-embedding-001 is fast + strong.
# NOTE: text-embedding-004 is retired on this endpoint — use gemini-embedding-001.
EMBEDDING_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="gemini-embedding-001"

# --- Dev/demo only. Leave unset in normal use. ---
# Corrupts one column's name in the PROMPT (never in validation), forcing the
# first attempt to hallucinate so the self-correction loop visibly recovers.
#   table.column              -> renames to <column>_x
#   table.column:replacement  -> renames to <replacement>
# Prefer an explicit, plausible replacement: given an obviously mangled name the
# model tends to "correct" it back and never misses.
# DEV_POISON_COLUMN="usr.full_nm:customer_name"

# --- Demo mode (optional) ---
# When set, POST /auth/demo creates an ephemeral sandbox tenant with this
# connection cloned in (schema profile, embeddings, and cached summary — no
# LLM calls). Point it at a fully scanned connection's id. Leave unset to
# disable demo mode entirely.
# DEMO_TEMPLATE_CONNECTION_ID=""
# Queries per demo tenant per hour (default 30).
# DEMO_QUERY_LIMIT_PER_HOUR="30"
