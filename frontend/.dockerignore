# Build context is frontend/. Everything here is either rebuilt inside the
# image or is a secret / local-only file.

# ── Rebuilt inside the image ─────────────────────────────────────────────────
node_modules
.next
*.tsbuildinfo

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.*
# .env.local is always a secret; .env.example is safe but unnecessary
.env.local
.env.example

# ── Dev / test artefacts ──────────────────────────────────────────────────────
*.log
npm-debug.log*
coverage
*.test.ts
*.spec.ts
__tests__

# ── OS / editor noise ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode
.idea

# ── Docker's own files ────────────────────────────────────────────────────────
Dockerfile
.dockerignore

# ── Repo metadata ─────────────────────────────────────────────────────────────
.git
.gitignore
